{
  "name": "yss-validator-js",
  "description": "YAML Schema Syntax - a human-friendly YAML-based payload validator",
  "author": "Alexandre Magro <alexandremagro@live.com>",
  "version": "1.0.1",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "src",
    "index.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alxmagro/yss-js.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "jest": "^30.2.0",
    "standard": "^17.1.2"
  },
  "scripts": {
    "repl": "node --import ./scripts/repl.js",
    "lint": "standard",
    "test": "NODE_NO_WARNINGS=1 node --experimental-vm-modules node_modules/.bin/jest",
    "test:specs": "node scripts/run-specs.js",
    "coverage": "NODE_NO_WARNINGS=1 node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "coverage:open": "xdg-open .coverage/lcov-report/index.html",
    "bm": "node benchmark/run.js",
    "bm:isolated": "node benchmark/isolated.js",
    "test:integration": "bash scripts/integration-test.sh"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testPathIgnorePatterns": ["test/integration"],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": ".coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ]
  },
  "standard": {
    "env": [
      "jest"
    ]
  },
  "keywords": [
    "yaml",
    "schema",
    "validation",
    "validator",
    "json"
  ],
  "license": "MIT"
}
