{
  "name": "yss",
  "description": "YAML Simplified Schema - a human-friendly YAML-based payload validator",
  "private": false,
  "author": "Alexandre Magro <alexandremagro@live.com>",
  "version": "0.1.0",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "jest": "^30.2.0",
    "standard": "^17.1.2"
  },
  "scripts": {
    "lint": "standard",
    "test": "NODE_NO_WARNINGS=1 node --experimental-vm-modules node_modules/.bin/jest",
    "test:specs": "node scripts/run-specs.js",
    "coverage": "NODE_NO_WARNINGS=1 node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "coverage:open": "xdg-open .coverage/lcov-report/index.html",
    "bm": "node benchmark/run.js",
    "bm:isolated": "node benchmark/isolated.js"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": ".coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ]
  },
  "standard": {
    "env": [
      "jest"
    ]
  },
  "keywords": [
    "yaml",
    "schema",
    "validation",
    "validator"
  ],
  "license": "MIT"
}
