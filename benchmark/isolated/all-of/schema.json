{
  "type": "object",
  "properties": {
    "product": {
      "allOf": [
        {
          "type": "object",
          "properties": {
            "name":  { "type": "string",  "minLength": 2, "maxLength": 80 },
            "price": { "type": "number",  "minimum": 0 }
          }
        },
        {
          "type": "object",
          "properties": {
            "sku":   { "type": "string",  "minLength": 6, "maxLength": 20 },
            "stock": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "properties": {
            "category": { "type": "string", "enum": ["electronics", "clothing", "food", "books"] },
            "active":   { "type": "boolean" }
          }
        }
      ]
    }
  }
}
