{
  "type": "object",
  "properties": {
    "name":   { "type": "string",  "minLength": 2, "maxLength": 50 },
    "email":  { "type": "string",  "format": "email" },
    "age":    { "type": "integer", "minimum": 18, "maximum": 120 },
    "score":  { "type": "number",  "minimum": 0,  "maximum": 100 },
    "role":   { "type": "string",  "enum": ["admin", "user", "guest"] },
    "active": { "type": "boolean" }
  }
}
