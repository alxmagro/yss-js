{
  "type": "object",
  "required": ["id", "username", "email", "role", "active", "address", "version"],
  "additionalProperties": false,
  "properties": {
    "id":       { "type": "integer", "minimum": 1 },
    "username": { "type": "string",  "minLength": 3, "maxLength": 32 },
    "email":    { "type": "string",  "format": "email" },
    "role":     { "type": "string",  "enum": ["admin", "editor", "viewer", "guest"] },
    "score":    { "type": "number",  "minimum": 0, "maximum": 100 },
    "level":    { "type": "integer", "exclusiveMinimum": 0, "exclusiveMaximum": 100 },
    "active":   { "type": "boolean" },
    "version":  { "const": 1 },
    "address": {
      "type": "object",
      "required": ["street", "city", "country"],
      "additionalProperties": false,
      "properties": {
        "street":  { "type": "string", "minLength": 1, "maxLength": 100 },
        "city":    { "type": "string", "minLength": 1, "maxLength": 60 },
        "country": { "type": "string", "minLength": 2, "maxLength": 2 },
        "zip":     { "type": "string", "pattern": "^[0-9]{5}$" }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 30 }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource", "actions"],
        "additionalProperties": false,
        "properties": {
          "resource": { "type": "string" },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["create", "read", "update", "delete"] }
          }
        }
      }
    },
    "contact": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "phone": { "type": "string", "pattern": "^\\+?[0-9\\s\\-]{7,15}$" }
          },
          "required": ["phone"]
        },
        {
          "type": "object",
          "properties": {
            "social": {
              "type": "object",
              "required": ["platform", "handle"],
              "properties": {
                "platform": { "type": "string", "enum": ["twitter", "linkedin", "github"] },
                "handle":   { "type": "string", "minLength": 1, "maxLength": 50 }
              }
            }
          },
          "required": ["social"]
        }
      ]
    }
  }
}
